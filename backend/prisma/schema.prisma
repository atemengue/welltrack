generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  timezone     String   @default("UTC")
  createdAt    DateTime @default(now())

  symptoms       Symptom[]
  symptomLogs    SymptomLog[]
  moodLogs       MoodLog[]
  medications    Medication[]
  medicationLogs MedicationLog[]
  habits         Habit[]
  habitLogs      HabitLog[]

  @@map("users")
}

// ─── Symptoms ────────────────────────────────────────────────────────────────

model Symptom {
  id       String  @id @default(uuid())
  userId   String? // null = system default
  name     String
  category String
  isActive Boolean @default(true)

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptomLogs SymptomLog[]

  @@map("symptoms")
}

model SymptomLog {
  id        String   @id @default(uuid())
  userId    String
  symptomId String
  severity  Int
  notes     String?
  loggedAt  DateTime
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptom Symptom @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("symptom_logs")
}

// ─── Mood ────────────────────────────────────────────────────────────────────

model MoodLog {
  id          String   @id @default(uuid())
  userId      String
  moodScore   Int
  energyLevel Int?
  stressLevel Int?
  notes       String?
  loggedAt    DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("mood_logs")
}

// ─── Medications ─────────────────────────────────────────────────────────────

model Medication {
  id        String   @id @default(uuid())
  userId    String
  name      String
  dosage    String?
  frequency String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicationLogs MedicationLog[]

  @@map("medications")
}

model MedicationLog {
  id           String    @id @default(uuid())
  userId       String
  medicationId String
  taken        Boolean
  takenAt      DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("medication_logs")
}

// ─── Habits ──────────────────────────────────────────────────────────────────

enum TrackingType {
  boolean
  numeric
  duration
}

model Habit {
  id           String       @id @default(uuid())
  userId       String? // null = system default
  name         String
  trackingType TrackingType
  unit         String?
  isActive     Boolean      @default(true)

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitLogs HabitLog[]

  @@map("habits")
}

model HabitLog {
  id            String   @id @default(uuid())
  userId        String
  habitId       String
  valueBoolean  Boolean?
  valueNumeric  Float?
  valueDuration Int? // minutes
  notes         String?
  loggedAt      DateTime
  createdAt     DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("habit_logs")
}
